# ===================================
# A股自选股智能分析系统 - 环境变量配置
# ===================================

# 自选股列表（逗号分隔，支持沪深两市代码）
# A股：600xxx, 601xxx, 603xxx, 000xxx, 002xxx, 300xxx
# 港股：00700.HK, 01800.HK
# 美股：AAPL, TSLA, GOOGL, MSFT
STOCK_LIST=600519,300750,002594,AAPL,TSLA

# ===================================
# AI 模型配置
# ===================================

# Anthropic Claude（已配置）
ANTHROPIC_API_KEY=sk-ant-api03-dF6Q0J7Hr3Qd-i9I7-Ip3xQl4-2jEKLH6eN0l9u8bH3-3a6YvWk5T
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI兼容接口（已配置）
# 使用火山引擎 Ark API
OPENAI_API_KEY=ec8ae51a-a126-4437-98dc-44c84b821229
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_MODEL=Doubao-Seed-2.0-Code

# 采样温度（0.0-2.0，默认 0.7；0 确定性最高，2 随机性最高）
LLM_TEMPERATURE=0.7

# ===================================
# 邮箱推送配置
# ===================================

# 使用QQ邮箱
EMAIL_SENDER=zqh110119@qq.com
# 邮箱密码（QQ邮箱使用授权码，不是登录密码）
# 请在QQ邮箱设置 -> 账户 -> POP3/SMTP服务 -> 生成授权码
EMAIL_PASSWORD=jhjrjowbtkywbjjd

# 收件人（留空则发给自己）
EMAIL_RECEIVERS=

# 邮箱发件人显示名称
EMAIL_SENDER_NAME=股票智能分析助手

# ===================================
# 推送配置
# ===================================

# 报告类型：simple(精简)、full(完整)、brief(3-5句概括)
REPORT_TYPE=simple

# 报告输出语言：zh(中文)、en(英文)
REPORT_LANGUAGE=zh

# 仅分析结果摘要
REPORT_SUMMARY_ONLY=false

# ===================================
# Agent 策略对话配置
# ===================================

# 启用 Agent 问股模式（默认 false）
AGENT_MODE=false
# Agent 主模型（留空时继承 OPENAI_MODEL）
AGENT_LITELLM_MODEL=
# Agent 最大推理步数（默认 10）
AGENT_MAX_STEPS=10

# ===================================
# 定时任务配置（本地运行）
# ===================================

# 是否启用定时任务（默认 false）
SCHEDULE_ENABLED=false
# 每日执行时间（HH:MM 格式，24小时制）
SCHEDULE_TIME=18:00
# 启动时是否立即执行一次分析
SCHEDULE_RUN_IMMEDIATELY=true

# 交易日检查（默认 true，非交易日跳过执行）
TRADING_DAY_CHECK_ENABLED=true

# ===================================
# 市场复盘配置
# ===================================

# 是否启用大盘复盘
MARKET_REVIEW_ENABLED=true
# 大盘复盘市场区域：cn(A股)、us(美股)、both(两者)
MARKET_REVIEW_REGION=cn

# ===================================
# 分析间隔配置（秒）
# ===================================

# 个股分析和大盘分析之间的延迟，避免API限流
ANALYSIS_DELAY=10

# ===================================
# 数据库配置
# ===================================

DATABASE_PATH=./data/stock_analysis.db

# ===================================
# 系统配置
# ===================================

# 日志目录
LOG_DIR=./logs
# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
# 最大并发线程数
MAX_WORKERS=3
# 是否启用调试日志
DEBUG=false

# ===================================
# Web UI 配置
# ===================================

# 是否默认启动 Web UI（默认 false）
WEBUI_ENABLED=false
# Web UI 监听地址（默认 127.0.0.1）
WEBUI_HOST=127.0.0.1
# Web UI 监听端口（默认 8000）
WEBUI_PORT=8000
# 启动 Web 服务前是否自动构建前端
WEBUI_AUTO_BUILD=true
# 反向代理下信任 X-Forwarded-For 获取真实 IP
TRUST_X_FORWARDED_FOR=false
